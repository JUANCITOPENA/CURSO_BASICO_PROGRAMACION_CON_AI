### 🧠 C. El Cerebro del Servidor (`api/gemini.js`)
Este es el archivo más importante. Recorre tu lista de modelos.
```javascript
export default async function handler(req, res) {
    // 1. Verificamos que sea una petición válida
    if (req.method !== "POST") return res.status(405).send("Usa el método POST");

    const { message } = req.body; // Recibimos tu pregunta
    const API_KEY = process.env.GEMINI_API_KEY; // Sacamos la llave del archivo .env

    // 2. Tu lista estratégica de modelos
    const MODELS = [
        "gemini-2.5-flash-lite",
        "gemini-3-flash-preview",
        "gemini-2.5-flash",
        "gemini-2.5-pro",
        "gemini-3.1-pro-preview"
    ];

    // 3. Intento en bucle (Si uno falla, el otro ayuda)
    for (const model of MODELS) {
        try {
            const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${API_KEY}`;
            const response = await fetch(url, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ contents: [{ parts: [{ text: message }] }] })
            });

            if (!response.ok) continue; // Si este modelo falla, sigue con el siguiente

            const data = await response.json();
            const text = data.candidates?.[0]?.content?.parts?.[0]?.text;

            if (text) return res.status(200).json({ reply: text }); // ¡Éxito!
        } catch (err) {
            continue; // Si hay error de red, sigue probando
        }
    }

    return res.status(500).json({ error: "No pude obtener respuesta de ningún modelo." });
}
```

